# macOS / Windows system files
.DS_Store
._*
Thumbs.db
Desktop.ini

# Editor and IDE metadata
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.tmp

# Environment and local config
.env
.env.*
!.env.example
*.local

# Dependencies and package manager caches
node_modules/
.npm/
.pnpm-store/

# Build and cache output
dist/
build/
out/
.cache/
.parcel-cache/
.vite/

# Python cache files, useful if scripts are added later
__pycache__/
*.py[cod]
.pytest_cache/

# Large local archives and generated exports
*.zip
*.tar
*.tar.gz
*.rar
*.7z
