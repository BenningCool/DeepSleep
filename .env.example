# ============================================================
# KPMG 企业邮箱 (@kpmg.com) · Microsoft 365 SMTP 配置
# ============================================================
# 服务器（全球 M365 通用）
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false

# 发件邮箱：须为 @kpmg.com 且有发信权限的账号
# 建议用团队专用邮箱，不要用 Partner 个人邮箱做测试
SMTP_USER=your.name@kpmg.com
SMTP_PASS=your-password-or-app-password

# 收件人看到的「发件人」名称
SMTP_FROM="DeepSleep <your.name@kpmg.com>"

# 本地邮件 API 端口（与 vite proxy 一致，一般不用改）
MAIL_PORT=3001

# ============================================================
# 配置说明
# ============================================================
# 1. 复制本文件为 .env：  cp .env.example .env
# 2. 填入你的 @kpmg.com 邮箱和密码
# 3. 启动：npm run dev（会同时启动 Vite + 邮件服务）
#
# 若发送失败，常见原因：
# - 公司禁用了 SMTP AUTH（需联系 KPMG IT 开通）
# - 账号启用了 MFA，需使用 App Password（若 IT 允许）
# - 防火墙拦截出站 587 端口
#
# 验证邮件服务是否就绪：
#   curl http://localhost:3001/api/health
